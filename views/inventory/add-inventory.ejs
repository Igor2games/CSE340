<section class="inventory-form-view" aria-labelledby="add-inventory-title">
  <h1 id="add-inventory-title"><%= title %></h1>

  <%- messages() %>

  <% if (errors) { %>
    <ul class="notice">
      <% errors.array().forEach((error) => { %>
        <li><%= error.msg %></li>
      <% }) %>
    </ul>
  <% } %>

  <div class="inventory-form-card">
    <p class="inventory-form-required">All fields are required.</p>

    <form class="inventory-form" action="/inv/add-inventory" method="post">
      <div class="form-row">
        <label for="classificationList">Classification</label>
        <%- classificationList %>
      </div>

      <div class="form-row">
        <label for="inv_make">Make</label>
        <input
          type="text"
          id="inv_make"
          name="inv_make"
          minlength="3"
          placeholder="Min of 3 characters"
          value="<%= locals.inv_make %>"
          required
        >
      </div>

      <div class="form-row">
        <label for="inv_model">Model</label>
        <input
          type="text"
          id="inv_model"
          name="inv_model"
          minlength="3"
          placeholder="Min of 3 characters"
          value="<%= locals.inv_model %>"
          required
        >
      </div>

      <div class="form-row">
        <label for="inv_description">Description</label>
        <textarea
          id="inv_description"
          name="inv_description"
          rows="4"
          required
        ><%= locals.inv_description %></textarea>
      </div>

      <div class="form-row">
        <label for="inv_image">Image Path</label>
        <input
          type="text"
          id="inv_image"
          name="inv_image"
          pattern="^/images/vehicles/.+"
          title="Path must begin with /images/vehicles/"
          value="<%= locals.inv_image %>"
          required
        >
      </div>

      <div class="form-row">
        <label for="inv_thumbnail">Thumbnail Path</label>
        <input
          type="text"
          id="inv_thumbnail"
          name="inv_thumbnail"
          pattern="^/images/vehicles/.+"
          title="Path must begin with /images/vehicles/"
          value="<%= locals.inv_thumbnail %>"
          required
        >
      </div>

      <div class="form-row">
        <label for="inv_price">Price</label>
        <input
          type="number"
          id="inv_price"
          name="inv_price"
          min="0"
          step="0.01"
          placeholder="decimal or integer"
          value="<%= locals.inv_price %>"
          required
        >
      </div>

      <div class="form-row">
        <label for="inv_year">Year</label>
        <input
          type="text"
          id="inv_year"
          name="inv_year"
          pattern="^\d{4}$"
          minlength="4"
          maxlength="4"
          inputmode="numeric"
          placeholder="4-digit year"
          value="<%= locals.inv_year %>"
          required
        >
      </div>

      <div class="form-row">
        <label for="inv_miles">Miles</label>
        <input
          type="text"
          id="inv_miles"
          name="inv_miles"
          pattern="^\d+$"
          inputmode="numeric"
          placeholder="digits only"
          value="<%= locals.inv_miles %>"
          required
        >
      </div>

      <div class="form-row">
        <label for="inv_color">Color</label>
        <input
          type="text"
          id="inv_color"
          name="inv_color"
          value="<%= locals.inv_color %>"
          required
        >
      </div>

      <button class="auth-submit" type="submit">Add Vehicle</button>
    </form>
  </div>
</section>
