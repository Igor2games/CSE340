<h1>Welcome to CSE Motors!</h1>

<%- messages() %>

<section class="hero" aria-labelledby="hero-title">
	<h2 id="hero-title" class="sr-only">Featured Vehicle</h2>
	<div class="hero-callout">
		<h3>DMC Delorean</h3>
		<ul>
			<li>3 Cup holders</li>
			<li>Superman doors</li>
			<li>Fuzzy dice!</li>
		</ul>
		<a class="hero-cta" href="#" aria-label="Own this Delorean today">
			<img src="/images/site/own_today.png" alt="Own Today">
		</a>
	</div>
	<img class="hero-vehicle" src="/images/vehicles/delorean.jpg" alt="Silver DMC Delorean">
</section>

<section class="home-panels" aria-label="Delorean updates and reviews">
	<article class="reviews">
		<h2>DMC Delorean Reviews</h2>
		<ul>
			<li>&quot;So fast it&apos;s almost magical!&quot;</li>
			<li>&quot;Cool doors and smooth drive every time.&quot;</li>
			<li>&quot;Looks futuristic and turns heads.&quot;</li>
			<li>&quot;This car feels legendary to own.&quot;</li>
			<li>&quot;4.5/5 stars from our customers.&quot;</li>
		</ul>
	</article>

	<article class="upgrades">
		<h2>Delorean Upgrades</h2>
		<div class="upgrade-grid">
			<a class="upgrade-card" href="#">
				<div class="upgrade-media">
					<img src="/images/upgrades/flux-cap.png" alt="Flux Capacitor upgrade">
				</div>
				<span>Flux Capacitor</span>
			</a>
			<a class="upgrade-card" href="#">
				<div class="upgrade-media">
					<img src="/images/upgrades/flame.jpg" alt="Flame decals upgrade">
				</div>
				<span>Flame Decals</span>
			</a>
			<a class="upgrade-card" href="#">
				<div class="upgrade-media">
					<img src="/images/upgrades/bumper_sticker.jpg" alt="Bumper sticker upgrade">
				</div>
				<span>Bumper Stickers</span>
			</a>
			<a class="upgrade-card" href="#">
				<div class="upgrade-media">
					<img src="/images/upgrades/hub-cap.jpg" alt="Hub caps upgrade">
				</div>
				<span>Hub Caps</span>
			</a>
		</div>
	</article>
</section>