<section class="account-view" aria-labelledby="account-management-title">
	<h1 id="account-management-title"><%= title %></h1>

	<%- messages() %>

	<% if (locals.accountData.account_type === "Client") { %>
		<h2>Welcome <%= locals.accountData.account_firstname %></h2>
		<p><a href="/account/update/<%= locals.accountData.account_id %>">Update Account Information</a></p>
	<% } else { %>
		<h2>Welcome <%= locals.accountData.account_firstname %></h2>
		<p><a href="/account/update/<%= locals.accountData.account_id %>">Update Account Information</a></p>
		<h3>Inventory Management</h3>
		<p><a href="/inv/" title="Go to Inventory Management">Manage Inventory</a></p>
		<% if (locals.accountData.account_type === "Admin") { %>
			<h3>Account Administration</h3>
			<p><a href="/account/manage-accounts" title="Manage user account roles">Manage Accounts</a></p>
		<% } %>
	<% } %>
</section>
