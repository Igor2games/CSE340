<section class="auth-view" aria-labelledby="register-title">
	<h1 id="register-title"><%= title %></h1>

	<%- messages() %>

	<div class="auth-card">
		<p class="auth-required-note">All fields are required.</p>

		<form class="auth-form" action="/account/register" method="post">
			<div class="form-row">
				<label for="account_firstname">First Name</label>
				<input
					type="text"
					id="account_firstname"
					name="account_firstname"
					autocomplete="given-name"
					value="<%= typeof account_firstname !== 'undefined' ? account_firstname : '' %>"
					required
				>
			</div>

			<div class="form-row">
				<label for="account_lastname">Last Name</label>
				<input
					type="text"
					id="account_lastname"
					name="account_lastname"
					autocomplete="family-name"
					value="<%= typeof account_lastname !== 'undefined' ? account_lastname : '' %>"
					required
				>
			</div>

			<div class="form-row">
				<label for="account_email">Email Address</label>
				<input
					type="email"
					id="account_email"
					name="account_email"
					autocomplete="email"
					value="<%= typeof account_email !== 'undefined' ? account_email : '' %>"
					required
				>
			</div>

			<div class="form-row">
				<label for="account_password">Password</label>
				<input
					type="password"
					id="account_password"
					name="account_password"
					autocomplete="new-password"
					required
				>
				<button class="password-toggle" type="button" id="password-toggle" aria-controls="account_password" aria-label="Show password">
					Show Password
				</button>
			</div>

			<div class="password-rules" aria-live="polite">
				<p>Password must be at least 12 characters and include:</p>
				<ul>
					<li>1 capital letter minimum</li>
					<li>1 number minimum</li>
					<li>1 special character minimum</li>
				</ul>
			</div>

			<button class="auth-submit" type="submit">Create Account</button>
		</form>
	</div>
</section>

<script>
	(function () {
		const toggleButton = document.getElementById("password-toggle")
		const passwordField = document.getElementById("account_password")

		if (!toggleButton || !passwordField) return

		toggleButton.addEventListener("click", function () {
			const showPassword = passwordField.type === "password"
			passwordField.type = showPassword ? "text" : "password"
			toggleButton.textContent = showPassword ? "Hide Password" : "Show Password"
			toggleButton.setAttribute("aria-label", showPassword ? "Hide password" : "Show password")
		})
	})()
</script>
